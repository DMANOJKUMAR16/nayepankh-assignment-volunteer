# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Get from: cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster1.5d9qxrc.mongodb.net/volunteerhub?retryWrites=true&w=majority&appName=Cluster1

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_replace_this

JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (for CORS) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
